# ============================================================================
# Emy Brain Service Configuration
# ============================================================================

# ============================================================================
# Service Configuration
# ============================================================================

# Host to bind to (0.0.0.0 = all interfaces, localhost for local only)
BRAIN_HOST=0.0.0.0

# Port to run Brain service on
BRAIN_PORT=8001

# Environment (development or production)
ENV=production

# ============================================================================
# Database Configuration
# ============================================================================

# Path to SQLite database file (Brain service)
# Use absolute path for Render deployment
# Default: emy_brain.db in current directory
BRAIN_DB_PATH=/data/emy_brain.db

# Main Emy database path
EMY_DB_PATH=emy/data/emy.db

# ============================================================================
# Job Queue Configuration
# ============================================================================

# Batch size for processing jobs from queue
QUEUE_BATCH_SIZE=10

# Polling interval in seconds (how often to check for new jobs)
QUEUE_POLL_INTERVAL=5

# ============================================================================
# WebSocket Configuration
# ============================================================================

# Heartbeat interval in seconds (for keeping connection alive)
WS_HEARTBEAT_INTERVAL=30

# ============================================================================
# Rate Limiting Configuration
# ============================================================================

# Maximum requests per client IP per time window
RATE_LIMIT_REQUESTS=100

# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW=60

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: path to log file (if not set, logs only to console)
# LOG_FILE=/var/log/emy_brain.log

# ============================================================================
# Monitoring Configuration (Optional)
# ============================================================================

# Sentry DSN for error tracking (optional)
# Leave empty to disable Sentry
# SENTRY_DSN=https://key@sentry.io/project-id

# Sentry environment tag
SENTRY_ENVIRONMENT=production

# ============================================================================
# Security Configuration
# ============================================================================

# CORS origins (comma-separated)
# Use * for development, specific origins for production
CORS_ORIGINS=*

# ============================================================================
# Agent Configuration
# ============================================================================

# Agent timeout in seconds
AGENT_TIMEOUT=300

# LangGraph debug mode (true/false)
LANGGRAPH_DEBUG=false

# ============================================================================
# Anthropic API
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# Emy Core Configuration
# ============================================================================

# Daily API budget (USD)
EMY_DAILY_BUDGET_USD=5.00

# Main log level (for Emy core agents)
EMY_LOG_LEVEL=INFO

# ============================================================================
# Sub-Agent Models
# ============================================================================

EMY_HAIKU_MODEL=claude-haiku-4-5-20251001
EMY_SONNET_MODEL=claude-sonnet-4-6
EMY_OPUS_MODEL=claude-opus-4-6

# ============================================================================
# Integrations (optional)
# ============================================================================

# OANDA Forex Trading
OANDA_ACCESS_TOKEN=
OANDA_ACCOUNT_ID=

# Pushover Notifications
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# ============================================================================
# Scheduling (EST timezone)
# ============================================================================

EMY_RUN_TRADING_HEALTH_CHECK=true
EMY_RUN_JOB_SEARCH=true
EMY_RUN_OBSIDIAN_UPDATE=true

# ============================================================================
# Optional: Cloud Storage (Future)
# ============================================================================

# S3 bucket for job result archival (optional)
# S3_BUCKET_NAME=emy-jobs-archive
# S3_REGION=us-east-1
