# OANDA API Configuration
OANDA_ACCESS_TOKEN=your_oanda_token_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ENV=practice  # or "live" for production

# Risk Management
RISK_PER_TRADE_PCT=0.5  # Percentage of account to risk per trade
DAILY_MAX_LOSS_PCT=2.0   # Maximum daily loss percentage
STOP_LOSS_PIPS=5         # Stop loss in pips
TAKE_PROFIT_PIPS=8       # Take profit in pips
MAX_CONSECUTIVE_LOSSES=3 # Stop trading after N consecutive losses

# Trading Parameters
MAX_SPREAD_PIPS=1.5      # Skip trades if spread exceeds this
TRADING_SESSIONS=London,NY_Overlap  # Comma-separated list
MIN_ACCOUNT_BALANCE=1000 # Minimum account balance to trade

# FT-DMI-EMA strategy (optional signal source)
# SEMI_AUTO/MANUAL: opportunity list is built and shown in UI; user enables and 15m trigger executes.
# AUTO: no list is shown; trades open automatically when all conditions met, capped by FT_DMI_EMA_MAX_TRADES.
FT_DMI_EMA_SIGNALS_ENABLED=false  # Set to true to enable FT-DMI-EMA (4H+1H setup, 15m Fisher trigger)
FT_DMI_EMA_PAIRS=  # Optional: comma-separated OANDA pairs (e.g. EUR_USD,GBP_USD). If empty, uses default list.
FT_DMI_EMA_MAX_TRADES=2  # Max concurrent FT-DMI-EMA trades in AUTO mode (ignored in SEMI_AUTO/MANUAL).

# Fisher Transform (FT) opportunities - pairs to scan for reversal signals
FISHER_PAIRS=  # Optional: comma-separated pairs (e.g. EUR_USD,GBP_USD or EUR/USD,GBP/USD). If empty, uses default list.

# Integration Paths
TRADE_ALERTS_PATH=../Trade-Alerts  # Path to Trade-Alerts for market_state.json
FX_ENGINE_PATH=../Fx-engine        # Path to Fx-engine for RL integration (optional)

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scalp_engine.log

