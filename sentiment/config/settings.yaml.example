# Application Settings
# Copy this file to settings.yaml and customize

# Schedule
check_interval_minutes: 15

# Market Data
price_lookback_hours: 24
news_lookback_hours: 24
use_oanda: true

# Sentiment Analysis
llm_provider: "openai"  # openai, anthropic, or gemini
llm_model: "gpt-4o-mini"
sentiment_confidence_threshold: 0.7

# Alerts
email_enabled: true
email_recipient: "your_email@example.com"

# Price Signal Thresholds
momentum_threshold_percent: 0.5  # 0.5% price move triggers investigation
volatility_increase_threshold: 1.5  # 1.5x ATR increase

# Logging
log_level: "INFO"
log_file: "logs/sentiment_monitor.log"






